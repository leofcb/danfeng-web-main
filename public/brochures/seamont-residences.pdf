    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/intlTelInput.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/utils.js" defer></script>
    <script>
        $(document).ready(function(){
            let  defualt_phone_setting = {
                initialCountry: "ae",
                preferredCountries: [
                    "ae", "gb", "in", "id", "my", "vn", "pk", "ph",
                    "cn", "ae", "eg", "jo", "qa", "kw", "om", "ma"
                ],
                utilsScript: "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/utils.js"
            };
            const phoneInputField = document.querySelector(".intl-phone");
            const phoneInput = window.intlTelInput(phoneInputField, defualt_phone_setting);
            const calBackInputField = document.querySelector(".call_back_phone");
            const call_back_phoneinput = window.intlTelInput(calBackInputField, defualt_phone_setting);

            const payment_plan_fieldInputField = document.querySelector(".payment_plan_field");
            const payment_plan_fieldinput = window.intlTelInput(payment_plan_fieldInputField, defualt_phone_setting);

            const floor_plan_fieldInputField = document.querySelector(".floor_plan_field");
            const floor_plan_fieldinput = window.intlTelInput(floor_plan_fieldInputField, defualt_phone_setting);

            const call_back_fieldInputField = document.querySelector(".call_back_field");
            const call_back_fieldinput = window.intlTelInput(call_back_fieldInputField, defualt_phone_setting);

            let brochure_phone_field = document.querySelector(".brochure_phone");
            const brochure_phoneInput = window.intlTelInput(brochure_phone_field, defualt_phone_setting);

            $("#userForm").submit(function(event) {
                event.preventDefault();
                if (!phoneInput.isValidNumber()) {
                    toastr.error('Please input a valid number.');
                    return;
                }
                const countryData = phoneInput.getSelectedCountryData();
                const dialingCode = countryData.dialCode;

                $('#loader').show();
                var formData = new FormData(this);
                formData.append("country_code", dialingCode);
                $.ajax({
                    url: '/list-property-form-save',
                    data: formData,
                    processData: false,
                    contentType: false,
                    method:'POST',
                    success: function(response) {
                        if(response.success){
                            $('#userForm')[0].reset();
                            toastr.success(response.message);
                            $('#listPropertyModal').modal('hide');
                        }else{
                            toastr.error(response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        toastr.error('Some error occured');
                    },complete:function(xhr) {
                        $('#loader').hide();
                    }
                });
            });

            $('.requestCallForm').submit(function(event) {
                event.preventDefault();
                let country_code ='';
                if ($(this).find('.call_back_field').length) {
                    if (!call_back_fieldinput.isValidNumber()) {
                        toastr.error('Please input a valid number.');
                        return;
                    }
                    const countryData = call_back_fieldinput.getSelectedCountryData();
                    country_code = countryData.dialCode;
                }else if($(this).find('.call_back_phone').length){
                    if (!call_back_phoneinput.isValidNumber()) {
                        toastr.error('Please input a valid number.');
                        return;
                    }
                    const countryData = call_back_phoneinput.getSelectedCountryData();
                    country_code = countryData.dialCode;
                }else if($(this).find('.payment_plan_field').length){
                    if (!payment_plan_fieldinput.isValidNumber()) {
                        toastr.error('Please input a valid number.');
                        return;
                    }
                    const countryData = payment_plan_fieldinput.getSelectedCountryData();
                    country_code = countryData.dialCode;
                }
                else if($(this).find('.floor_plan_field').length){
                    if (!floor_plan_fieldinput.isValidNumber()) {
                        toastr.error('Please input a valid number.');
                        return;
                    }
                    const countryData = floor_plan_fieldinput.getSelectedCountryData();
                    country_code = countryData.dialCode;
                } else if($(this).find('.brochure_phone').length){
                    if (!brochure_phoneInput.isValidNumber()) {
                        toastr.error('Please input a valid number.');
                        return;
                    }
                    const countryData = brochure_phoneInput.getSelectedCountryData();
                    country_code = countryData.dialCode;
                }

                var form_data = $(this).serializeArray();
                form_data.push({name: 'source', value: window.location.href});
                form_data.push({name: 'country_code', value: country_code});
                var serialized_form_data = $.param(form_data);
                var form = this;
                var pdf_link = $(this).find('input[name="download_pdf"]').val();
                $('#loader').show();
                $.ajax({
                    type: 'POST',
                    url: 'request/call',
                    data: serialized_form_data,
                    success: function(response) {
                        $('#loader').hide();
                        if(response.success) {
                            if((typeof pdf_link !== 'undefined') && pdf_link.length) {
                                window.open(pdf_link, '_blank');
                            }
                            toastr.success('Your request submitted successfully');
                            form.reset();
                            window.location.href = 'thankyou';
                        }
                        else {
                            toastr.error(response.message);
                        }
                    },
                    error: function(jqXHR, textStatus, errorThrown) {
                        $('#loader').hide();
                        toastr.error('An error occurred: ' + errorThrown);
                    }
                });
                return false;
            });

            $('#total_amount_input, #down_payment_input, #interest_rate_input, #loan_period_input').keyup(function(){
                var total_amount = $('#total_amount_input').val();
                var down_payment = $('#down_payment_input').val();
                var interest_rate = $('#interest_rate_input').val();
                var loan_period = $('#loan_period_input').val();

                var principal = total_amount - down_payment;
                $('#principal_amount_input').val(principal);

                var monthly_interest_rate = interest_rate/100/12;
                var loan_term_in_months = loan_period*12;
                var monthly_payment = ((monthly_interest_rate*principal)/(1-1/Math.pow(1+monthly_interest_rate,loan_term_in_months))).toFixed(0);

                var total_payment = (monthly_payment*loan_term_in_months).toFixed(0);

                $('#estimate_pay').text(monthly_payment);
                $('#total_amount').text(total_payment);
                $('#monthly_payments_input').val(monthly_payment);

                $('#total_amount_display').text(total_amount);
            });
        });
        var video = document.getElementById("my-video");
        var playButton = document.getElementById("play-button");

        playButton.addEventListener("click", function() {
            if (video.paused) {
                video.play();
                playButton.innerHTML = '<i class="fas fa-pause"></i>';

            } else {
                video.pause();
                playButton.innerHTML = '<i class="fas fa-play"></i>';
            }
        });
        video.addEventListener("mouseleave", function() {
// Check if the mouse is not over the play/pause button before hiding it
            if (!isMouseOverButton()) {
                playButton.classList.add("hidden");
            }
        });

        video.addEventListener("mouseenter", function() {
            playButton.classList.remove("hidden");
        });

        playButton.addEventListener("mouseenter", function() {
            playButton.classList.remove("hidden");
        });

        playButton.addEventListener("mouseleave", function() {
// Check if the mouse is not over the video before hiding the play/pause button
            if (!isMouseOverVideo()) {
                playButton.classList.add("hidden");
            }
        });

        function isMouseOverButton() {
// Check if the mouse is over the play/pause button
            var rect = playButton.getBoundingClientRect();
            return (
                rect.left <= event.clientX &&
                event.clientX <= rect.right &&
                rect.top <= event.clientY &&
                event.clientY <= rect.bottom);
        }

        function isMouseOverVideo() {
            var rect = video.getBoundingClientRect();
            return (
                rect.left <= event.clientX &&
                event.clientX <= rect.right &&
                rect.top <= event.clientY &&
                event.clientY <= rect.bottom);
        }
        // toastr.options = {
        //     positionClass: 'toast-top-right'
        // };
    </script>
    
