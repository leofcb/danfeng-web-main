  <script>
window.onscroll = function() {myFunction()};
// Get the header
var header = document.getElementById("header");
// Get the offset position of the navbar
var sticky = header.offsetTop;
// Add the sticky class to the header when you reach its scroll position. Remove "sticky" when you leave the scroll position
function myFunction() {
  if (window.pageYOffset > sticky) {
    header.classList.add("sticky");
  } else {
    header.classList.remove("sticky");
  }
}

var productsCount = 3; // replace with the actual count of products
if (productsCount > 3) {
  var loop = true;
} else {
  var loop = false;
}

$('.tabs').owlCarousel({
  loop: loop,
   margin:0,
   nav: true,
autoplay:true,
 autoplayTimeout:6000,
    autoplayHoverPause:true,
	rewind:false,
           responsive: {
                0: {
                    items: 1
                },
                600: {
                    items: 1
                },
				700: {
                    items: 1
                },
                1000: {
                    items: 3
                }
            }
});

$(document).ready(function(){
  $(".masterCarousel").owlCarousel({
      items: 1,
      loop: true,
      nav: true,
      dots: true,
      autoplay: false,
  });

  $('.master-next-btn').click(function() {
    $(".masterCarousel").trigger('next.owl.carousel');
  });
  $('.master-pre-btn').click(function(){
  $(".masterCarousel").trigger('prev.owl.carousel');
  })

        $(".subcomunities").owlCarousel({
            loop: true,
            margin: 10,
            nav: true,
            dots: true,
            responsive: {
                0:{
                    items:1,
                },
                600:{
                    items:2,
                },
                990:{
                    items:3,
                },
                1200:{
                    items:4,
                }
            }
        });

        /* use for theme2 quicklinks */
        $('.quicklinks').owlCarousel({
          items: 5,
          loop: true,
          margin: 20,
          autoplay:true,
          autoplayTimeout:5000,
          autoplayHoverPause:true,
          responsive:{
              0:{
                  items:1,
              },
              600:{
                  items:2,
              },
              990:{
                  items:3,
              },
              1200:{
                  items:4,
              }
          }
        });
        $('.customNextBtn').click(function() {
          $('.quicklinks').trigger('next.owl.carousel');
        });
        $('.customPrevBtn').click(function() {
          $('.quicklinks').trigger('prev.owl.carousel', [300]);
        });
    });

    var splide = new Splide('.splide', {
      type: 'loop',
      perPage: 3,
      rewind: true,
      breakpoints: {
        640: {
          perPage: 2,
          gap: '.7rem',
          height: '12rem',
        }
        ,
        480: {
          perPage: 1,
          gap: '.7rem',
          height: 'auto',
        }
        ,
      }
      ,
    }
         );
    splide.mount();

 </script>
    </body>
</html>
