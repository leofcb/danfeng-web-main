                                            </div>
                                                                            </div>
                            </div>
                        </div>
                                            </div>
                </div>
            </section>
        
            <!-------------Start FEATURES------------>
                    <section id="amenities">
                <div class="container">
                                            <div class="row">
                            <h2 class="text-dark text-center mb-1">Seamont Autograph Collection Residences Amenities</h2>
                            <p class="text-center mb-3 ">At Seamont Autograph Collection Residences, every amenity is thoughtfully designed to elevate daily living into a resort-style experience. Residents can unwind by the infinity pool overlooking the Arabian Gulf, stay active in the state-of-the-art fitness center, or relax in exclusive spa and wellness lounges. With 24-hour concierge service, secure parking, and seamless waterfront access, Seamont redefines island living through luxury, comfort, and convenience at every level.</p>
                        </div>
                    
                                            <div class="row  align-items-center justify-content-center " >
                                                            <div class="col-lg-2 col-6 mb-3 amenities">
                                    <div class="d-flex border align-items-center ">
                                        <div class="icon" style="background-color:var(--color-primary)">
                                            <img alt="amenity" src="https://seamont-autograph.com/storage/ameneties/November2025/MIX1gdm8WwbAx0ASU6kX.png" width="30" height="30" loading="lazy">
                                        </div>
                                        <p class="mb-0">Adult &amp; Kids Swimming Pools</p>
