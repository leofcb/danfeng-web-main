<div class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal [.text-message+&amp;]:mt-1" dir="auto" data-message-author-role="assistant" data-message-id="edd72255-a4e0-4a49-9920-9fbb04e19b9c" data-message-model-slug="gpt-5">
