    <style>
        @media (max-width: 991px) and (min-width: 767px) {
            .download-brochure-btn{
                display:none;
            }
        }
        .card-custom {
            height: 330px;
            border-radius: 18px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.123);
            overflow: hidden;
            position: relative;
            text-decoration: none;
            display: block;
        }
        .card-custom img {
            border-radius: 8px;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .card-content {
            position: absolute;
            bottom: 0;
            width: 100%;
            padding: 0.4em 1.5em;
            font-size: 14px;
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(5px);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.164);
            transform: scale(0.95);
            transition: all 0.4s;
        }

        .card-content p {
            font-size: 0.8em;
        }
        @media (max-width: 1279px) {
            .comm-ul{
                background:none !important;
                min-width:400px !important;
                border:none !important;
            }
            .comm-ul>li, .lang-ul>li{
                border:none !important;
            }
        }
        @media (max-height: 650px) and (min-width: 1280px) {
            .requestCallForm {
                max-width: 500px;
                margin: auto;
            }
            .large-screen-div{
                display: none;
            }
            .mobile_div{
                display: block !important;
            }

            .request .row {
                display: flex;
                flex-wrap: wrap;
            }
            .request {
                width: 68%;
            }
            .request .h4 {
                font-weight:bold;
            }

            .request .row .col-md-12 {
                width: 50%;
                padding-right: 0;
            }

            .request .row .col-md-12:nth-child(2n) {
                margin-right: 0;
            }

            .request .row .col-md-12.mt-2 {
                width: 100%;
            }

        }
        @media (max-width: 500px) {
            .overlay {
                height: 128.5% !important;
            }
        }
        @media (min-width: 1280px) and (max-width: 1440px) {
            .navbar>ul>li {
                padding:6px 0 6px 15px;
            }
        }
        #loader {
            position: fixed;
            z-index: 9999;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(255, 255, 255, 0.7);
        }

        .loader-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border-radius: 50%;
            width: 50px;
            height: 50px;
            border: 5px solid #f3f3f3;
            border-top: 5px solid #3498db;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }
            100% {
                transform: rotate(360deg);
            }
        }
        @media (min-width: 768px) {
            #demo .carousel-control-prev {
                position: absolute;
                left: -62px;
            }
            #demo .carousel-control-next {
                position: absolute;
                right: -62px;
            }
            .master-pre-btn{
                position: absolute;
                left: -5%;
                background: grey;
            }
            .master-next-btn{
                position: absolute;
                right: -6% !important;
                background: grey;
            }
        }
        @media (min-width: 994px) {
            #demo .carousel-control-prev {
                position: absolute;
                left: -110px;
            }
            #demo .carousel-control-next {
                position: absolute;
                right: -110px;
            }
            .master-pre-btn{
                position: absolute;
                left: -32px;
                background: grey;
            }
            .master-next-btn{
                position: absolute;
                right: -40px !important;
                background: grey;
            }
            .splide__arrow--prev{
                left:-4%;
            }
            .splide__arrow--next{
                left:100.2%;
            }
        }
        .iti--allow-dropdown{
            width:100%
        }
        .iti__country-list{
            max-width:375px;
            overflow-x: hidden;
        }
        .intl-phone, .call_back_phone,.payment_plan_field, .floor_plan_field, .call_back_field, .brochure_phone{
            padding-left:50px !important;
        }

        .list-property-btn:hover{
            background: white !important;
            color:grey !important;
        }
        #hero h2, #hero h4, #hero h6 {
            cursor:default;''
        }
        .splide__pagination{
            display:none !important;
        }

        .request-call-div{
            border-radius: 2%;
            padding: 13px;
        }
        .comm-ul>li, .lang-ul>li{
            border-bottom: 1px solid #c7c5c5;
        }
        .comm-ul, .lang-ul{
            width:auto !important;
            padding:0 !important;
            background: rgba(0, 0, 0, 0.3) !important;
            backdrop-filter: blur(5px) !important;
        }
        .comm-ul>li:hover, .lang-ul>li:hover{
            border-color:#bb957a;
        }

        .logo-box {
            position: absolute;
            top: 24px;
            left: 0;
            background-color: white;
            padding: 5px 8px;
            border-top-right-radius: 4px;
            border-bottom-right-radius: 4px;
            z-index: 2;

            width: 60px;  /* Adjust based on your needs */
            height: 45px; /* Adjust based on your needs */
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden; /* Prevent image overflow */
        }

        .logo-box img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }
