/* Start custom CSS for shortcode, class: .elementor-element-8027d58 */.community-section-home .first_row, .community-section-home .second_row {
    display: flex;
}
.community-section-home .first_row {
    gap: 38px;
    margin-bottom: 100px;
}
.community-section {
    flex-basis: 33.33%;
    display: flex;
    flex-direction: column;
}
.image-title-location-wrapper {
    position: relative;
    flex: 1;
}
.title-location-wrapper {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}
.image-title-location-wrapper  img {
    background: rgba(65, 65, 65, 0.30);
    mix-blend-mode: multiply;
    height: 100%;
    width: 100%;
    object-fit: cover;
}
.community-title,
.community-location{
    font-family: acumin-pro;
    font-size: 18px;
    font-style: normal;
    font-weight: 500;
    line-height: 28px; /* 155.556% */
    letter-spacing: 0.072px;
    text-align: center;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
}
.community-location {
    font-size: 13.75px;
    letter-spacing: 0.055px;
    text-transform: none;
}

.community-section-home .second_row {
    width: 100%;
}
.community-section-home .second_row .community-section {
    flex-basis: 100%;
}
.community-section-home .second_row .community-section img {
    width: 100%;
    height: auto;
    min-height: 750px;
    max-height: 750px;
}
.community-excerpt {
    font-family: acumin-pro;
    font-size: 13.75px;
    font-style: normal;
    font-weight: 500;
    line-height: 28px; /* 203.636% */
    letter-spacing: 0.055px;
    color: #878787;
    text-transform: lowercase;
    margin: 0;
}
.community-excerpt:first-letter {
    text-transform: uppercase;
}
.community-section {
    flex-basis: 33.33%;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
}
.image-title-location-wrapper {
    position: relative;
    width: 100%;
    flex: auto;
    height: 430px;
    margin-bottom: 12px;
        background: rgba(65, 65, 65, 0.30);
    mix-blend-mode: multiply;
}
@media screen and (min-width: 768px) and (max-width: 1023px) {
    .community-section-home .first_row {
        flex-wrap: wrap;
    }
    .community-section {
        flex-basis: calc(50% - 19px);
    }
}
@media screen and (max-width: 767px) {
    .community-section-home .first_row {
        flex-wrap: wrap;
    }
    .community-section {
        flex-basis: 100%;
    }
}

.community-section {
    flex-direction: column !important;
}
.community-section .image-title-location-wrapper {
    
    flex: 0;
}
.community-excerpt {
    flex: 1;
}
.image-title-location-wrapper img {
    height: auto;
    aspect-ratio: 1.5;
}
.community-section .wrap-details {
    flex:1;
    display: flex;
}/* End custom CSS */
/* Start Custom Fonts CSS */@font-face {
	font-family: 'Teodor';
	font-style: normal;
	font-weight: normal;
	font-display: auto;
	src: url('https://ellingtonproperties.ae/wp-content/uploads/Teodor-Regular.ttf') format('truetype');
