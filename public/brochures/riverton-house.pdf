<script id="summerpromotion">
(function () {
    const storageKey = "summerPromotionPopupShown";

    function initSummerPopup() {
        const isHomePage =
            document.body.classList.contains("home") ||
            document.body.classList.contains("front-page");

        // Do not show on homepage
        if (isHomePage) return;

        // Do not show again in the same browser session
        if (sessionStorage.getItem(storageKey) === "true") return;

        // Prevent multiple timers if this script is loaded more than once
        if (window.summerPromotionPopupTimerStarted) return;
        window.summerPromotionPopupTimerStarted = true;

        setTimeout(function () {
            // Save before opening the popup
            sessionStorage.setItem(storageKey, "true");

            // Find both relative and full URL popup links
            const trigger = document.querySelector(
                'a[href="#summer-promotion-pup"], a[href$="#summer-promotion-pup"]'
            );

            if (trigger) {
                trigger.click();
            } else {
                // Fallback used by your original working script
                window.location.hash = "summer-promotion-pup";
            }
        }, 5000);
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initSummerPopup);
    } else {
        initSummerPopup();
    }
})();
</script>
