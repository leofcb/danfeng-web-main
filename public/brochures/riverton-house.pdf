<script>
$(document).ready(function() {

    $("#PhoneNumber").CcPicker({
        "countryCode": "ae"
    });

    // phone number length

    $(".uae_number").attr('maxlength', '10');

    $(".uae_number").on("countrySelect", function(e, i) {



        if (i.phoneCode != "971") {

            $(".uae_number").attr('maxlength', '12');

        } else {

            $(".uae_number").attr('maxlength', '10');

        }

    });

});







