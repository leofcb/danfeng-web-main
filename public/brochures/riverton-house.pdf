    display: inline-block;
    background-color: #b49e8c00;
    color: #000000;
    border: 1px solid black;
    padding: 6px 16px;
    font-size: 10px;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 1.3px;
    cursor: pointer;
    text-align: center;
}

.listing-cta-2:hover {
    background-color: #AA8D74;
    border: 1px solid #AA8D74;
    color: #ffffff !important;
}/* End custom CSS */
